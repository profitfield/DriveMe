# Server
PORT=3000
NODE_ENV=development
HOST=localhost

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=driveme
DB_USER=driveme_user
DB_PASSWORD=driveme_pass

# Redis
REDIS_URL=redis://localhost:6379

# JWT Auth
JWT_SECRET=change-this-in-production
JWT_REFRESH_SECRET=change-this-refresh-secret-in-production
JWT_EXPIRES_IN=30d

# Security
ENCRYPTION_KEY=your-secure-encryption-key-min-32-chars
CSRF_SECRET=your-secure-csrf-secret-key
FILE_ENCRYPTION_KEY=your-secure-file-encryption-key-min-32-chars

# File Storage
UPLOAD_PATH=storage/secure
MAX_FILE_SIZE=10485760  # 10MB in bytes
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp,application/pdf,text/plain
MALWARE_SCAN_ENABLED=true

# File Upload Categories
DOCUMENTS_MAX_SIZE=10485760  # 10MB
IMAGES_MAX_SIZE=5242880      # 5MB
AVATARS_MAX_SIZE=2097152     # 2MB

# Secure Storage
SECURE_FILES_PATH=storage/secure
SECURE_TEMP_PATH=storage/temp
QUARANTINE_PATH=storage/quarantine

# Antivirus
ANTIVIRUS_ENABLED=true
CLAMAV_HOST=localhost
CLAMAV_PORT=3310
CLAMAV_TIMEOUT=60000
CLAMAV_DB_PATH=/var/lib/clamav
MAX_FILE_SCAN_SIZE=100485760  # 100MB
QUARANTINE_ENABLED=true
QUARANTINE_RETENTION_DAYS=30

# File Processing
FILE_PROCESS_TIMEOUT=300000  # 5 minutes
MAX_FILE_PROCESS_RETRIES=3
CONCURRENT_FILE_PROCESSES=5

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_BOT_NAME=your_bot_name_here
TELEGRAM_WEBHOOK_URL=https://your-domain.com/telegram/webhook

# Commission
COMMISSION_RATE=0.25

# Prices
# Premium & Premium Large
PREMIUM_FIRST_HOUR=4200
PREMIUM_MINUTE_RATE=70
PREMIUM_AIRPORT_SVO=6000
PREMIUM_AIRPORT_DME=7000
PREMIUM_AIRPORT_VKO=6000

# Elite
ELITE_FIRST_HOUR=4800
ELITE_MINUTE_RATE=80
ELITE_AIRPORT_SVO=7000
ELITE_AIRPORT_DME=8000
ELITE_AIRPORT_VKO=7000

# Hourly discounts (%)
DISCOUNT_2_HOURS=5
DISCOUNT_4_HOURS=10
DISCOUNT_6_HOURS=15
DISCOUNT_8_HOURS=20
DISCOUNT_10_HOURS=25
DISCOUNT_12_HOURS=30

# App URLs
CLIENT_APP_URL=https://t.me/your_client_bot
DRIVER_APP_URL=https://t.me/your_driver_bot
ADMIN_PANEL_URL=http://localhost:3000

# Logs
LOG_LEVEL=debug
LOG_PATH=logs
LOG_RETENTION_DAYS=30

# Security
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100

# Notifications
NOTIFICATION_RETENTION_DAYS=30
NOTIFICATION_RATE_LIMIT_PER_USER=50
NOTIFICATION_RATE_LIMIT_WINDOW=3600

# Audit
AUDIT_LOG_RETENTION_DAYS=90
AUDIT_ENABLED=true

# Bruteforce Protection
MAX_LOGIN_ATTEMPTS=5
LOGIN_BLOCK_DURATION=1800    # 30 minutes
ADMIN_MAX_LOGIN_ATTEMPTS=3
ADMIN_BLOCK_DURATION=3600    # 1 hour

# Chat
CHAT_MESSAGE_RETENTION_DAYS=30
MAX_MESSAGE_LENGTH=1000
CHAT_RATE_LIMIT_PER_USER=50
CHAT_RATE_LIMIT_WINDOW=3600