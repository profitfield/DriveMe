# Server
PORT=3000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=driveme
DB_USER=driveme_user
DB_PASSWORD=driveme_pass

# Redis
REDIS_URL=redis://localhost:6379

# JWT Auth
JWT_SECRET=change-this-in-production
JWT_EXPIRES_IN=30d

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_BOT_NAME=your_bot_name_here
TELEGRAM_WEBHOOK_URL=https://your-domain.com/telegram/webhook

# Commission
COMMISSION_RATE=0.25

# Prices
# Premium & Premium Large
PREMIUM_FIRST_HOUR=4200
PREMIUM_MINUTE_RATE=70
PREMIUM_AIRPORT_SVO=6000
PREMIUM_AIRPORT_DME=7000
PREMIUM_AIRPORT_VKO=6000

# Elite
ELITE_FIRST_HOUR=4800
ELITE_MINUTE_RATE=80
ELITE_AIRPORT_SVO=7000
ELITE_AIRPORT_DME=8000
ELITE_AIRPORT_VKO=7000

# Hourly discounts (%)
DISCOUNT_2_HOURS=5
DISCOUNT_4_HOURS=10
DISCOUNT_6_HOURS=15
DISCOUNT_8_HOURS=20
DISCOUNT_10_HOURS=25
DISCOUNT_12_HOURS=30

# App URLs
CLIENT_APP_URL=https://t.me/your_client_bot
DRIVER_APP_URL=https://t.me/your_driver_bot
ADMIN_PANEL_URL=http://localhost:3000

# Logs
LOG_LEVEL=debug

# Security
CORS_ORIGINS=http://localhost:3000
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100