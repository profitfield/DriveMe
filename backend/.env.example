// .env.example

# Server Configuration
NODE_ENV=development
PORT=3000
HOST=localhost

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=driveme
DB_USER=driveme_user
DB_PASSWORD=driveme_pass

# JWT Configuration
JWT_SECRET=change_this_to_32_char_or_longer_secret
JWT_REFRESH_SECRET=change_this_refresh_to_32_char_or_longer
JWT_EXPIRES_IN=24h

# Admin Access
ADMIN_EMAIL=admin@driveme.com
ADMIN_PASSWORD=your_hashed_password_here

# Telegram Integration
TELEGRAM_BOT_TOKEN=7647410594:AAHn7y1W6TIxwnheDAAoT94U9Ql1onVy-XA
TELEGRAM_BOT_NAME=DriveMe_MSK
TELEGRAM_WEBHOOK_URL=https://api.driveme.com/telegram/webhook

# Business Logic
COMMISSION_RATE=0.25

# Prices - Premium & Premium Large
PREMIUM_FIRST_HOUR=4200
PREMIUM_MINUTE_RATE=70
PREMIUM_AIRPORT_SVO=6000
PREMIUM_AIRPORT_DME=7000
PREMIUM_AIRPORT_VKO=6000

# Prices - Elite
ELITE_FIRST_HOUR=4800
ELITE_MINUTE_RATE=80
ELITE_AIRPORT_SVO=7000
ELITE_AIRPORT_DME=8000
ELITE_AIRPORT_VKO=7000

# Hourly Discounts (%)
