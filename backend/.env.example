DISCOUNT_4_HOURS=10
DISCOUNT_6_HOURS=15
DISCOUNT_8_HOURS=20
DISCOUNT_10_HOURS=25
DISCOUNT_12_HOURS=30

# Security
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,https://admin.driveme.com
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379